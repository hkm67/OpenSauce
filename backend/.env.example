SECRET_KEY=change-me-in-production
DATABASE_PATH=opensauce.db
TOKEN_EXPIRES_SECONDS=86400

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/oauth/github/callback

# After GitHub login, redirect back to the Vite app so it can store the JWT.
OAUTH_SUCCESS_REDIRECT=http://localhost:3000/oauth/callback
OAUTH_TOKEN_IN_FRAGMENT=1
# AUTH_COOKIE_NAME=opensauce_token
# AUTH_COOKIE_SECURE=1
# OAUTH_JSON_RESPONSE=1

# Demo accounts: usernames demo_alice, demo_bob, demo_carol, demo_david, demo_eve — password demo123.
# Requires a backend restart after you enable this so init_db() can seed or refresh rows.
# OPENSAUCE_SEED_DEMO=1
