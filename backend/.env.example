SECRET_KEY=change-me-in-production
DATABASE_PATH=opensauce.db
TOKEN_EXPIRES_SECONDS=86400

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/oauth/github/callback

# After GitHub login: 302 to this URL. JWT is not put in the query string.
# OAUTH_SUCCESS_REDIRECT=http://localhost:3000/
# If your UI runs on another port (SPA), add token in URL fragment for JS to read:
# OAUTH_TOKEN_IN_FRAGMENT=1
# AUTH_COOKIE_NAME=opensauce_token
# AUTH_COOKIE_SECURE=1
# OAUTH_JSON_RESPONSE=1
