SECRET_KEY=change-me-in-production
TOKEN_EXPIRES_SECONDS=86400

# Docker Compose uses a local Postgres service at db:5432.
DB_URL_TEMPLATE=postgresql://opensauce:[YOUR-PASSWORD]@db:5432/opensauce
DB_PASSWORD=opensauce
LOCAL_AUTH_ENABLED=true

# For production/non-Docker Supabase Auth, set these and disable LOCAL_AUTH_ENABLED.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Local OAuth/frontend URLs.
GITHUB_REDIRECT_URI=http://localhost:8000/oauth/github/callback
OAUTH_SUCCESS_REDIRECT=http://localhost:3000/oauth/callback
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Public-facing base URL of the API (no trailing slash).
# Used in generated SKILL.md URLs and magic links so agents get the real host.
# Local Docker/dev should point at the local backend.
PUBLIC_BASE_URL=http://localhost:8000
GITHUB_CACHE_TTL_SECONDS=300
GITHUB_CACHE_MAX_ITEMS=256
APP_CACHE_TTL_SECONDS=60
APP_CACHE_MAX_ITEMS=512

# Frontend build variables. Use the backend origin for Docker/local OAuth redirects.
VITE_API_BASE_URL=http://localhost:8000

# Production custom-domain values:
# GITHUB_REDIRECT_URI=https://api.opensauce.itdogtics.com/oauth/github/callback
# OAUTH_SUCCESS_REDIRECT=https://opensauce.itdogtics.com/oauth/callback
# CORS_ALLOWED_ORIGIN=https://opensauce.itdogtics.com
# PUBLIC_BASE_URL=https://api.opensauce.itdogtics.com
# VITE_API_BASE_URL=https://api.opensauce.itdogtics.com
