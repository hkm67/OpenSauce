SECRET_KEY=change-me-in-production
TOKEN_EXPIRES_SECONDS=86400

# Public-facing base URL of the API (no trailing slash).
# Used in generated SKILL.md URLs and magic links so agents get the real host.
# Leave empty to let the API auto-detect from the incoming request (fine for local dev).
# Example for production: PUBLIC_BASE_URL=https://api.yourdomain.example
PUBLIC_BASE_URL=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Set to your domain in production; defaults to localhost when left empty.
GITHUB_REDIRECT_URI=https://yourdomain.example/oauth/github/callback

# After GitHub login the backend redirects the browser here.
# Defaults to http://localhost:3000/oauth/callback when left empty.
OAUTH_SUCCESS_REDIRECT=https://yourdomain.example/oauth/callback

# Append the JWT as a URL fragment so the SPA on a different origin can read it.
OAUTH_TOKEN_IN_FRAGMENT=1

# Uncomment in production (HTTPS only):
# AUTH_COOKIE_SECURE=1

# Uncomment to seed demo accounts (requires a backend restart):
# OPENSAUCE_SEED_DEMO=1
